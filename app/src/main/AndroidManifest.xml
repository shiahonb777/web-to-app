        <!--
            NodeService - Node.js 嵌入式运行时的独立子进程容器。
            
            为什么单独开一个 OS 进程：
              libnode.so 一旦 dlopen + V8 init 就**永远 reset 不了**。如果跑在主进程：
                1) 用户 server.js 抛 SyntaxError / 调 process.exit 会让宿主进程死
                2) 切换项目 / 上次崩了想重试都没法做，必须用户从最近任务列表把
                   App 划掉再重开——非常糟糕的用户体验
              把它关到 :nodejs 子进程后，V8 死活都关在子进程里，主进程稳如磐石。
              要重启 V8 时主进程让子进程自杀，Android Framework 自动重建——零感知。
            
            android:process=":nodejs"  → 同 APK 内的独立 OS 进程（前导冒号表示
                                          private process，跟 webtoapp 共享 UID
                                          但有独立的 zygote-fork 出来的进程）
            isolatedProcess=false      → 我们要访问 filesDir / nativeLibraryDir，
                                          isolatedProcess 模式下连这些都拿不到
            stopWithTask=false         → 用户从最近任务划掉 App 时仍然让子进程
                                          一起死（true 是默认值，写出来是为了
                                          清楚——避免误以为子进程会比主进程
                                          活更久）
        -->
        <service
            android:name=".core.nodejs.NodeService"
            android:enabled="true"
            android:exported="false"
            android:process=":nodejs"
            android:stopWithTask="true" />

        <!--
            BootReceiver / ScheduledStartReceiver
            宿主使用：用户在 host 内可配置"开机自启某个 webapp"和"定时启动"；
                    BootReceiver 同时也兼容 shell 子 APK（同源代码同步过来）。
        -->
        <receiver
            android:name=".core.autostart.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".core.autostart.ScheduledStartReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.webtoapp.ACTION_SCHEDULED_START" />
            </intent-filter>
        </receiver>

        <!--
            Port query / release receivers
            宿主使用：跨 webapp 端口协调（Node/PHP/Python/Go 多运行时共存时）。
            exported=true 是因为多个由 WebToApp 打包出的 APK 之间需要互相广播查询端口。
        -->
        <receiver
            android:name=".core.port.PortQueryReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.webtoapp.action.PORT_QUERY" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".core.port.PortReleaseReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.webtoapp.action.PORT_RELEASE" />
            </intent-filter>
        </receiver>

        <!--
            BridgeAlarmReceiver - 宿主使用：通知调度（页内 Web Notification.scheduleNotification）
        -->
        <receiver
            android:name=".core.notification.BridgeAlarmReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.webtoapp.bridge.SCHEDULED_NOTIFICATION" />
            </intent-filter>
        </receiver>

        <!--
            ====== 已从宿主 manifest 删除（仅子 APK 使用）======
            <service .core.forcedrun.ForcedRunAccessibilityService>
                无障碍服务，仅子 APK 强制运行模式使用。无障碍服务的存在本身就会触发
                国产安全引擎的 PUA 启发式（金山/腾讯系），且宿主代码路径里不会进入
                ForcedRun 模式（grep ForcedRunManager 调用方仅出现在 ShellActivity）。

            <service .core.forcedrun.ForcedRunGuardService>
                specialUse 前台服务，强制运行守护进程。同上，仅子 APK 使用。

            <receiver .core.forcedrun.ForcedRunReceiver>
                强制运行启停广播接收器。同上，仅子 APK 使用。

            上述三者依然在 shell/src/main/AndroidManifest.xml 中声明，子 APK 打包时随
            模板带入；ApkBuilder 通过 buildRequiredPermissions/applyUsesPermissions
            按用户配置裁剪。
        -->

        <service
            android:name=".core.background.BackgroundRunService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="background_run" />
        </service>

        
        <service
            android:name=".core.notification.NotificationPollingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="notification_polling" />
        </service>
        
        
        <service
            android:name=".core.floatingwindow.FloatingWindowService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_window" />
        </service>
    
    </application>

</manifest>
