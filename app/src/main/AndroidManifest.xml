<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
    ==========================================================================
    权限声明策略（2026-05 修订）
    ==========================================================================
    本 manifest 只声明「宿主 app 本体」运行需要的权限和组件。

    设计原则：
      1. 用户打包的子 APK 如需 SMS / 通话 / 通讯录 / 日历 / 定位 / 传感器 /
         NFC / USB / 后台服务 等高危能力，由 ApkBuilder 在打包时按用户勾选
         动态注入到**子包**的 manifest，不预声明在宿主 manifest 里。
      2. 仅供子 APK 使用的运行时组件（强制运行 / 无障碍服务 / 强制运行守护
         前台服务等）只在 shell 模板 manifest 中声明，不混入宿主 manifest。
         宿主自身不会实例化这些组件，预声明只会让国产安全引擎做"组件指纹
         聚合"时把宿主误判为驻留型可疑应用。

    若有新的宿主功能真的需要某个权限/组件，请：
      1. 在本文件添加并注释"宿主使用：xxx 功能"
      2. 在代码里能被 grep 到对应 API 调用
    禁止再把"给子 APK 准备"的权限/组件写进本文件。
    ==========================================================================
    -->

    <!-- ====== 网络（宿主必需：加载网页、下载运行时、推送请求）====== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ====== 存储 / 媒体（宿主必需：选择图标、导入 HTML、素材库）====== -->
